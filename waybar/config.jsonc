/*=======================================================================
--------------------------------SETTINGS---------------------------------
=======================================================================*/
{
  "layer": "top",
  "position": "top",
  
  "blur": true,
  "modules-left": [
    "tray", 
    "niri/window"
  ],
  "modules-center": [
    "clock#1",
    "clock#2"
  ],
  "modules-right": [
    "group/audio-drawer",
    "group/btop-drawer",
    "backlight",
    "niri/language",
    "bluetooth",
    "network",
    "group/power",
  ],

  /*=======================================================================
  ----------------------------------TRAY-----------------------------------
  =======================================================================*/
  "tray": {
    "icon-size": 25,
    "spacing": 10,
    "show-passive-items": true,
    "reverse-direction": true,
  },
  /*=======================================================================
  ----------------------------------WINDOW---------------------------------
  =======================================================================*/
  "niri/window": {
    "format": "{}",
    "max-length": 60,
    "separate-outputs": false,
  },

  /*=======================================================================
  --------------------------------DATE AND TIME----------------------------
  =======================================================================*/
  "clock#1": {
    "type": "clock",
    "format": "ï€— {:%H:%M}",
    "tooltip-format": "{tz_list}",
    "on-click": "none",
    "tooltip": true,
    "timezones": [
        "",
        "Europe/Moscow",
        "Europe/Paris",
        "America/New_York",
        "Asia/Tokyo"
      ],
      "actions": {
          "on-scroll-up": "tz_up",
          "on-scroll-down": "tz_down"
      }
  },
  "clock#2": {
    "type": "clock",
    "format": "ï‘• {0:%d.%m.%Y}",
    "on-click": "none",
    "tooltip": true,
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
  },
  /*=======================================================================
------------------------------------SOUND--------------------------------
=======================================================================*/
  "group/audio-drawer": {
    "type": "hbox",
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 400,
      "children-class": "audio-extended",
      "transition-left-to-right": true,
    },
    "modules": ["pulseaudio#output", "pulseaudio#input"],
  },

  "pulseaudio#output": {
    "format": "{icon} {volume}%",
    "format-icons": {
      "headphone": "َ°‹‹",
      "default": ["َ°•؟", "َ°–€", "َ°•¾"],
    },
    "format-muted": "َ°–پ {volume}%",
    "on-click": "pavucontrol",
    "tooltip-format": "Output: {desc}\nذ›ذڑذœ: pavucontrol",
  },

  "pulseaudio#input": {
    "format": "{format_source}",
    "format-source": "ï„° {volume}%",
    "format-source-muted": "ï„± {volume}%",
    "tooltip-format": "Microphone: {desc}",
    "tooltip-format-muted": "Muted {desc}",
    "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
    "on-scroll-up": "pactl set-source-volume @DEFAULT_SOURCE@ +5%",
    "on-scroll-down": "pactl set-source-volume @DEFAULT_SOURCE@ -5%",
    "scroll-step": 1,
  },
  /*===========================================================================
  ------------------------------------BTOP-------------------------------------
  ===========================================================================*/
"group/btop-drawer": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 500,
      "children-class": "btop-extended",
      "transition-left-to-right": false,
    },
    "modules": [
      "custom/btop-trigger",
      "temperature",
      "memory",
      "cpu",
      "battery",
    ],
  },

  "custom/btop-trigger": {
    "format": "btop",
    "on-click": "kitty -e btop",
    "tooltip-format": "ذ›ذڑذœ: btop++",
  },
  /*===========================================================================
  ---------------------------------BATTERY-------------------------------------
  ===========================================================================*/
  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15,
    },
    "interval": 30,
    "format": "{capacity}% {icon}",
    "format-full": "{capacity}% {icon}",
    "format-charging": "{capacity}% َ°‚„",
    "format-plugged": "{capacity}% ï‡¦",
    "format-alt": "{time} َ±§¦",
    // "format-good": "َ±ˆ‘",
    "format-full": "full َ±ں¢",
    "format-icons": {
      "charging": ["َ°¢œ", "َ°‚†", "َ°‚‡", "َ°‚ˆ", "َ°¢‌", "َ°‚‰", "َ°¢‍", "َ°¢‍", "َ°‚ٹ", "َ°‚…"],
      "default": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
    },
  },
  "battery#bat2": {
    "bat": "BAT2",
  },

  /*===========================================================================
  -----------------------------------CPU---------------------------------------
  ===========================================================================*/
  "cpu": {
      "interval": 2,
      "states": {
        "warning": 70,
        "critical": 90
      },
      "format": "{icon} {usage}%",
      "format-alt": "{avg_frequency} GHz َ°» ",
      "format-icons": [
        "îچ¯", 
        "َ°ˆ¸", 
        "َ±——"
      ],
      "tooltip-format": "<tt>Total Usage: {usage}%\nLoad Avg:    {load}\n\nAvg Freq:    {avg_frequency} GHz\nMax Freq:    {max_frequency} GHz\nMin Freq:    {min_frequency} GHz</tt>"
    },
  /*===========================================================================
  -----------------------------------MEMORY------------------------------------
  ===========================================================================*/
    "memory": {
        "interval": 3,
        "states": {
          "warning": 80,
          "critical": 95
        },
        "format": "î؟… {percentage}%",
        "format-alt": "î؟… {used:.1f}G/{total:.1f}G", 
        
        "tooltip-format": "    === RAM ===\nUsage:      {percentage}%\nUsed:       {used:.1f} GiB\nAvailable:  {avail:.1f} GiB\nTotal:      {total:.1f} GiB\n\n   === SWAP ===\nUsage:      {swapPercentage}%\nUsed:       {swapUsed:.1f} GiB\nAvailable:  {swapAvail:.1f} GiB\nTotal:      {swapTotal:.1f} GiB"
      },

  /*===========================================================================
  -----------------------------------TEMPERATURE----------------------------------
  ===========================================================================*/
    "temperature": {
        "interval": 2,
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}آ°C",
        "format-critical": "{icon} {temperatureC}آ°C ïگ،",
        "format-icons": ["ï‹‹", "ï‹ٹ", "ï‹‰", "ï‹ˆ", "ï‹‡"],
        "tooltip-format": "Celsius:    {temperatureC}آ°C\nFahrenheit: {temperatureF}آ°F"
        },

  /*===========================================================================
  -----------------------------------BACKLIGHT---------------------------------
  ===========================================================================*/
    "backlight": {
        "scroll-step": 5,
        "format": "{icon} {percent}%",
        "format-icons": ["َ±©ژ", "َ±©ڈ", "َ±©گ", "َ±©‘", "َ±©’", "َ±©“", "َ±©”", "َ±©•", "َ±©–", "َ°›¨"],
        "format-alt": "َ°›¨ Brightness: {percent}%",
    },

  /*===========================================================================
  -----------------------------------LANGUAGE----------------------------------
  ===========================================================================*/
  "niri/language": {
      "format": "َ°ŒŒ {}", 
      "format-en": "EN",
      "format-us": "US",
      "format-ru": "RU",
      "format-uk": "UA",
      "format-by": "BY",
      "format-kz": "KZ",
      "format-de": "DE",
      "format-fr": "FR",
      "format-es": "ES",
      "format-it": "IT",
      "format-pl": "PL",
  }, 
  /*===========================================================================
  -----------------------------------NETWORK------------------------------------
  ===========================================================================*/
  "network": {
      "interval": 2,
      "format-wifi": "{icon} {signalStrength}%",
      "format-ethernet": "َ°ˆپ Wired",
      "format-disconnected": "َ°ˆ‚ Disconnected",
      "format-icons": [
        "َ°¤¯",
        "َ°¤ں",
        "َ°¤¢",
        "َ°¤¥",
        "َ°¤¨"
      ],
      "tooltip-format-wifi": "=== Wi-Fi Network ===\nSSID:       {essid}\nSignal:     {signalStrength}%\nInterface:  {ifname}\nIP Address: {ipaddr}\n\nTraffic:    â†“ {bandwidthDownBytes}  â†‘ {bandwidthUpBytes}\n\n[L-Click] Network Menu  [M-Click] Wireshark  [R-Click] Zapret",
      "tooltip-format-ethernet": "=== Ethernet Connection ===\nInterface:  {ifname}\nIP Address: {ipaddr}\n\nTraffic:    â†“ {bandwidthDownBytes}  â†‘ {bandwidthUpBytes}\n\n[L-Click] Network Menu  [M-Click] Wireshark  [R-Click] Zapret",
      "tooltip-format-disconnected": "=== Network ===\nStatus: Disconnected",
      "on-click": "kitty -e nmtui",
      "on-click-middle": "exec wireshark",
      "on-click-right": "kitty -e zapret"
    },
/*===========================================================================
-----------------------------------POWER-------------------------------------
===========================================================================*/
  "group/power": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 500,
      "children-class": "btop-extended",
      "transition-left-to-right": false,
    },
    "modules": ["custom/power", "custom/reboot", "custom/quit"],
  },

  "custom/power": {
    "format": "َ°گ¥",
    "on-click": "poweroff",
    "tooltip": false,
  },

  "custom/reboot": {
    "format": " َ°¦› ",
    "on-click": "reboot",
    "tooltip": false,
  },

  "custom/quit": {
    "format": " î©µ ",
    "on-click": "swaylock",
    "tooltip": false,
  },
  /*===========================================================================
  -----------------------------------BLUETOOTH---------------------------------
  ===========================================================================*/
  "bluetooth": {
    // ذڑذ¾ذ³ذ´ذ° ذ±ذ»رژر‚رƒذ· ذ²ذ؛ذ»رژر‡ذµذ½, ذ½ذ¾ رƒرپر‚ر€ذ¾ذ¹رپر‚ذ²ذ° ذ½ذµ ذ؟ذ¾ذ´ذ؛ذ»رژر‡ذµذ½ر‹
    "format": "َ°‚¯",

    // ذڑذ¾ذ³ذ´ذ° ذ±ذ»رژر‚رƒذ· ذ²ر‹ذ؛ذ»رژر‡ذµذ½
    "format-disabled": "َ°‚²",

    // ذڑذ¾ذ³ذ´ذ° ذ؟ذ¾ذ´ذ؛ذ»رژر‡ذµذ½ذ¾ رƒرپر‚ر€ذ¾ذ¹رپر‚ذ²ذ¾ (ذ؟ذ¾ذ؛ذ°ذ¶ذµر‚ ذ¸ذ؛ذ¾ذ½ذ؛رƒ "ذ؟ذ¾ذ´ذ؛ذ»رژر‡ذµذ½" ذ¸ ذ¸ذ¼رڈ ذ´ذµذ²ذ°ذ¹رپذ°)
    "format-connected": "َ°‚± {device_alias}",

    // ذ•رپذ»ذ¸ رƒ ذ؟ذ¾ذ´ذ؛ذ»رژر‡ذµذ½ذ½ذ¾ذ³ذ¾ ذ´ذµذ²ذ°ذ¹رپذ° ذµرپر‚رŒ ذ±ذ°ر‚ذ°ر€ذµذ¹ذ؛ذ° (ذ½ذ°ذ؟ر€ذ¸ذ¼ذµر€, ذ½ذ°رƒرˆذ½ذ¸ذ؛ذ¸)
    "format-connected-battery": "َ°‚± {device_alias} َ°¥‰ {device_battery_percentage}%",

    // ذ¢رƒذ»ر‚ذ¸ذ؟ر‹, ر‡ر‚ذ¾ذ±ر‹ ذ؟ر€ذ¸ ذ½ذ°ذ²ذµذ´ذµذ½ذ¸ذ¸ ذ¼ر‹رˆذ¸ ذ²ذ¸ذ´ذµر‚رŒ ذ؟ذ¾ذ´ر€ذ¾ذ±ذ½ذ¾رپر‚ذ¸
    "tooltip-format": "ذڑذ¾ذ½ر‚ر€ذ¾ذ»ذ»ذµر€: {controller_alias}\n{num_connections} ذ؟ذ¾ذ´ذ؛ذ»رژر‡ذµذ½ذ¾",
    "tooltip-format-connected": "ذڑذ¾ذ½ر‚ر€ذ¾ذ»ذ»ذµر€: {controller_alias}\n\nذںذ¾ذ´ذ؛ذ»رژر‡ذµذ½ذ¾:\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "â€¢ {device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "â€¢ {device_alias}\t{device_address}\tًں”‹{device_battery_percentage}%",

    // ذ›ذڑذœ ذ¾ر‚ذ؛ر€ر‹ذ²ذ°ذµر‚ ذ¼ذµذ½ذµذ´ذ¶ذµر€ ذ±ذ»رژر‚رƒذ·ذ°
    "on-click": "blueman-manager",
  },
}
